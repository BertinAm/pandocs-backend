# Copy this file to .env and fill in your values

# Django
DJANGO_SECRET_KEY=your-very-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (leave blank to use SQLite)
# DATABASE_URL=postgres://user:password@localhost:5432/pandocs

# Redis (required for WebSocket multi-process channel layer)
# REDIS_URL=redis://127.0.0.1:6379

# CORS — comma-separated extra origins beyond the defaults
# CORS_EXTRA_ORIGINS=https://yourapp.example.com
