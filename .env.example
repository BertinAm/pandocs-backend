# Copy this file to .env and fill in your values

# Django
DJANGO_SECRET_KEY=your-very-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (leave blank to use SQLite)
# In production, set this to Render's INTERNAL Database URL (services in the
# same Render region reach it over the private network for free).
# DATABASE_URL=postgres://user:password@localhost:5432/pandocs

# Database backups — only used by `python manage.py backup_db` / the
# db-backup.yml GitHub Actions workflow. Set DATABASE_URL_EXTERNAL as a repo
# secret (not here) since CI runners are outside Render's private network
# and need the EXTERNAL Database URL instead.
# BACKUP_S3_BUCKET=your-s3-bucket-name
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1

# Redis — required for the Django Channels WebSocket layer to broadcast
# across processes/instances. Without it, falls back to an in-memory layer
# that only works within a single process (fine for local dev only).
REDIS_URL=redis://127.0.0.1:6379

# CORS — comma-separated extra origins beyond the defaults
# CORS_EXTRA_ORIGINS=https://yourapp.example.com
